# PostgreSQL MCP Universal — Configuration
# Copy to .env and adjust

# Server port
PG_MCP_PORT=8090

# Log level: DEBUG, INFO, WARNING, ERROR
PG_MCP_LOG_LEVEL=INFO

# Default database URI (optional, for single-db quick start)
# PG_MCP_DATABASE_URI=postgresql://user:password@localhost:5432/mydb

# Access mode: "unrestricted" (read/write) or "restricted" (read-only)
PG_MCP_ACCESS_MODE=unrestricted

# Query timeout in seconds
PG_MCP_QUERY_TIMEOUT=30

# Connection pool
PG_MCP_POOL_MIN_SIZE=2
PG_MCP_POOL_MAX_SIZE=10

# Metadata cache TTL (seconds)
PG_MCP_METADATA_CACHE_TTL=600

# Session idle timeout (seconds, default 8 hours)
PG_MCP_SESSION_TIMEOUT=28800

# API key for Bearer auth (leave empty to disable auth)
PG_MCP_API_KEY=

# In-memory rate limiting for auth-sensitive endpoints.
PG_MCP_RATE_LIMIT_ENABLED=true
PG_MCP_RATE_LIMIT_WINDOW_SECONDS=60
PG_MCP_RATE_LIMIT_MCP_REQUESTS=60
PG_MCP_RATE_LIMIT_API_REQUESTS=60
PG_MCP_RATE_LIMIT_OAUTH_REQUESTS=10

# Compatibility OAuth token endpoint (/oauth/token): false by default.
# When enabled, endpoint requires client_secret == PG_MCP_API_KEY.
PG_MCP_ENABLE_SIMPLE_TOKEN_ENDPOINT=false
